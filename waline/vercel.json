{
  "rewrites": [
    { "source": "/comment", "destination": "/api/comment" },
    { "source": "/comment/(.*)", "destination": "/api/comment/$1" },
    { "source": "/counter", "destination": "/api/comment" },
    { "source": "/user", "destination": "/api/comment" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "https://hio42.asia" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, PUT, DELETE, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, Authorization" }
      ]
    }
  ]
}
